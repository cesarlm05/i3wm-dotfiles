#!/bin/bash
# m3wal genera este archivo la primera vez que se aplica un wallpaper; si
# nunca corrio (build de AUR fallida o sin wallpaper), usamos colores por
# defecto en vez de abortar y dejar la sesion sin bloqueo de pantalla.
if [ -f ~/.cache/m3-colors/colors.sh ]; then
    source ~/.cache/m3-colors/colors.sh
else
    color0="#2E3440"; color1="#BF616A"; color4="#81A1C1"; color5="#B48EAD"
    color7="#E5E9F0"; on_surface="#ECEFF4"; on_surface_variant="#D8DEE9"
fi

# Cache wallpaper path
WALLPAPER=~/.config/m3-colors/current-rofi.jpg
LOCK_IMG="/tmp/lockscreen.png"

# Darken dan blur wallpaper (adjust -50 untuk lebih/kurang gelap), o un fondo
# solido si todavia no hay wallpaper cacheado por m3wal
if [ -f "$WALLPAPER" ]; then
    magick "$WALLPAPER" -brightness-contrast -20x0 -blur 0x5 "$LOCK_IMG"
else
    magick -size 1920x1080 xc:"${color0}" "$LOCK_IMG"
fi

# i3lock-color-only flags (--clock, --ring-color, etc). Plain i3lock (the
# fallback installed when the i3lock-color AUR build fails) doesn't recognize
# them and would exit with an error, so detect support before using them.
if i3lock --help 2>&1 | grep -q -- "--ring-color"; then
    i3lock \
      --image "$LOCK_IMG" \
      --fill \
      --clock \
      --time-str="%H:%M" \
      --date-str="%A, %d %B" \
      --radius 120 \
      --ring-width 10 \
      --inside-color="${color0}00" \
      --ring-color="${color7}88" \
      --line-color="${color0}00" \
      --keyhl-color="${color4}ff" \
      --bshl-color="${color1}ff" \
      --separator-color="${color0}00" \
      --insidever-color="${color0}00" \
      --ringver-color="${color5}ff" \
      --insidewrong-color="${color1}33" \
      --ringwrong-color="${color1}ff" \
      --time-color="${on_surface}ff" \
      --date-color="${on_surface_variant}ff" \
      --verif-color="${color7}ff" \
      --wrong-color="${color1}ff" \
      --nofork
else
    i3lock --image "$LOCK_IMG" --nofork
fi
